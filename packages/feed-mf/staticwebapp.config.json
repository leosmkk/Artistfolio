{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/remoteEntry.js"]
  },
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type"
  },
  "mimeTypes": {
    ".js": "application/javascript"
  }
}
